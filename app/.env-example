APP_NAME=scraper-worker
NODE_ENV=development
LOG_LEVEL=debug

HTTP_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/136.0.0.0 Safari/537.36

PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_HEADLESS=false
PLAYWRIGHT_TIMEOUT_MS=30000
PLAYWRIGHT_NAVIGATION_TIMEOUT_MS=30000

SEARCH_PROVIDER_TIMEOUT_MS=45000
SEARCH_DEFAULT_FINAL_LIMIT=20
SEARCH_DEFAULT_COLLECT_LIMIT=100
SEARCH_MAX_COLLECT_LIMIT=200

RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123
RABBITMQ_QUEUE_BUSCA=fila.busca.produtos
RABBITMQ_PREFETCH=1
RABBITMQ_HEARTBEAT=30